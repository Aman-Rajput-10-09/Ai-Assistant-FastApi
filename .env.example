# App Config
PROJECT_NAME="AI Scheduling Assistant Backend"
ENV=development
DEBUG=true

# Database Config
DATABASE_URL="postgresql+asyncpg://your_username:your_password@assitant-db.cvqgm4cakw3b.ap-south-1.rds.amazonaws.com:5432/your_database"
DB_CONNECT_TIMEOUT_SECONDS=5
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Security Config
SECRET_KEY="replace-this-with-a-very-secure-random-key"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Gemini API Config
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_MODEL_TEXT="gemini-2.5-flash"
GEMINI_MODEL_TEXT_FALLBACKS="gemini-2.0-flash,gemini-flash-latest"
GEMINI_MODEL_EMBED="models/gemini-embedding-001"

# Redis Config
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
