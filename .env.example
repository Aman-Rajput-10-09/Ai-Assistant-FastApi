# App Config
PROJECT_NAME="AI Scheduling Assistant Backend"
ENV=development
DEBUG=true

# Database Config
DATABASE_URL="postgresql+asyncpg://your_username:your_password@assitant-db.cvqgm4cakw3b.ap-south-1.rds.amazonaws.com:5432/your_database"

# Security Config
SECRET_KEY="replace-this-with-a-very-secure-random-key"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Gemini API Config
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_MODEL_TEXT="gemini-3.5-flash"
GEMINI_MODEL_TEXT_FALLBACKS="gemini-flash-latest,gemini-2.5-flash"
GEMINI_MODEL_EMBED="models/text-embedding-004"

# Redis Config
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
